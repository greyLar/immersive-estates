# ─── ImmersiveEstates Environment Variables ───

# Server
PORT=3001
NODE_ENV=development

# Notifications
NOTIFICATION_EMAIL=you@immersive-estates.com
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_PLACE_ID/review

# Email (SendGrid) — set EMAIL_ENABLED=true to activate
EMAIL_ENABLED=false
SENDGRID_API_KEY=
EMAIL_FROM=hello@immersive-estates.com

# SMS (Twilio) — set SMS_ENABLED=true to activate
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+15551234567

# Google Calendar — set CALENDAR_ENABLED=true to activate
CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=

# Frontend (used during build)
VITE_API_URL=http://localhost:3001/api